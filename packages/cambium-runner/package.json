{
  "name": "@redwood-labs/cambium-runner",
  "version": "0.8.0",
  "description": "TS runtime for Cambium — executes compiled IR produced by the Cambium Ruby DSL.",
  "license": "MIT",
  "author": {
    "name": "Stephen Keider",
    "email": "hello@redwoodlabs.ai"
  },
  "homepage": "https://redwoodlabs.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redwood-labs-ai/cambium.git",
    "directory": "packages/cambium-runner"
  },
  "bugs": {
    "url": "https://github.com/redwood-labs-ai/cambium/issues"
  },
  "keywords": [
    "llm",
    "ai",
    "agent",
    "runtime",
    "typebox",
    "validation",
    "prompt-engineering",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.49",
    "ajv": "8.18.0",
    "pdfjs-dist": "5.6.205",
    "smol-toml": "1.6.1",
    "undici": "8.1.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "12.9.0",
    "quickjs-emscripten": "0.32.0",
    "sqlite-vec": "0.1.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.17",
    "typescript": "5.9.3"
  }
}
