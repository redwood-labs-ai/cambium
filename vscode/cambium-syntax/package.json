{
  "name": "cambium-syntax",
  "displayName": "Cambium DSL",
  "description": "Syntax highlighting, hover docs, go-to-definition, and completions for Cambium (.cmb.rb)",
  "version": "0.6.0",
  "publisher": "cambium",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:cambium"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cambium",
        "aliases": ["Cambium", "cambium"],
        "extensions": [".cmb.rb"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cambium",
        "scopeName": "source.cambium",
        "path": "./syntaxes/cambium.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cambium",
        "path": "./snippets/cambium.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0"
  }
}
