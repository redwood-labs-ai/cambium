{
  "name": "cambium",
  "version": "0.1.0-pre",
  "description": "Rails for generation engineering — CLI for building reliable LLM programs with Cambium's Ruby DSL.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cambium": "./cli/cambium.mjs"
  },
  "files": [
    "cli",
    "ruby"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "run": "node ./cli/cambium.mjs",
    "compile": "ruby ./ruby/cambium/compile.rb",
    "test": "npm run build && vitest run",
    "build": "npm run build --workspace @cambium/runner"
  },
  "dependencies": {
    "@cambium/runner": "0.1.0-pre",
    "dotenv": "^17.4.1",
    "smol-toml": "^1.6.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
