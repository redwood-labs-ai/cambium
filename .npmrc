# Cambium npm hardening — supply-chain defenses
# See SECURITY.md "Lean direct dependencies" and CLAUDE.md "Dependency policy"
# for the policy this file enforces.

# Pin: any version written to package.json by `npm install <pkg>` is exact —
# no caret, no tilde. Ranges drift on `npm update`; pinned versions don't.
save-exact=true

# Lockfile is authoritative. Never silently downgrade to non-lockfile installs
# (e.g., on CI runners that delete the lockfile by accident).
package-lock=true

# Respect `engines` in package.json. If a contributor's npm/node is too old,
# fail loudly rather than installing with a version mismatch.
engine-strict=true

# Minimum age — npm 11.5+ refuses to install any package version published
# less than this many days ago. Silently ignored on older npm; the custom
# `scripts/check-dep-ages.mjs` (run via `npm run audit:ages` and at publish
# time) is the version-independent enforcement.
#
# 7 days is the chosen window: bad publishes are typically caught within
# 24-72h, but Shai-Hulud-style worms can lurk longer. Shorter widens the
# window for compromised packages; longer slows legitimate patch flow.
minimum-release-age=7

# Audit at install time. `low` is too noisy; `moderate` catches real issues.
audit-level=moderate

# Suppress funding spam — not relevant to install correctness.
fund=false

# NOTE: npm's config priority is `npm_config_*` env vars > project `.npmrc` >
# user `~/.npmrc` > global > built-in. A CI pipeline or Dockerfile setting
# `npm_config_save_exact=false`, `npm_config_package_lock=false`, or
# `npm_config_minimum_release_age=0` silently overrides every setting in
# this file. CI runners and container builds MUST NOT set those vars.
